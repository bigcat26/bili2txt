# --- yt-dlp (B 站下载) ---
# 可选：会员 / 高画质视频需要登录态，把浏览器导出的 cookies.txt 路径填这里
# 浏览器导出插件推荐 "Get cookies.txt LOCALLY"
YTDLP_COOKIES=

# 下载清晰度：audio(仅音频,默认最省带宽) / 360 / 480 / 720 / 1080 / best(最高)
DOWNLOAD_QUALITY=audio

# --- ASR (语音转文字) ---
# faster-whisper 模型大小，可选: tiny / base / small / medium / large-v3
# tiny=~75MB 最快最糙, base=~150MB, small=~500MB, medium=~1.5GB, large-v3=~3GB 最准
WHISPER_MODEL=base
WHISPER_DEVICE=auto            # auto / cpu / cuda
WHISPER_COMPUTE_TYPE=int8      # int8 / float16 / float32 (M1/M2 用 int8)
WHISPER_LANGUAGE=              # 留空自动检测，指定填 zh / en / ja 等

# Hugging Face 镜像（国内下载模型用，海外用户留空即可）
# HF_ENDPOINT=https://hf-mirror.com

# --- LLM (总结) ---
# 任何 OpenAI 兼容接口都可用，下面给几个常见默认值：
#   deepseek:    https://api.deepseek.com/v1   + model=deepseek-chat
#   硅基流动:    https://api.siliconflow.cn/v1 + model=Qwen/Qwen2.5-32B-Instruct
#   openai:      https://api.openai.com/v1     + model=gpt-4o-mini
#   自部署 ollama: http://localhost:11434/v1   + model=qwen2.5:7b
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# --- 总结 prompt 风格 ---
# 可选: default / bullets / academic / casual
SUMMARY_STYLE=default